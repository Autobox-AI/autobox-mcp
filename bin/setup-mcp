#!/bin/bash

set -e

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

echo -e "${GREEN}🚀 Autobox MCP Setup${NC}"
echo "================================"

# Step 1: Build Docker image
echo -e "\n${YELLOW}Step 1: Building Docker image...${NC}"
./bin/docker-build
if [ $? -eq 0 ]; then
    echo -e "${GREEN}✓ Docker image built successfully${NC}"
else
    echo -e "${RED}✗ Failed to build Docker image${NC}"
    exit 1
fi

# Step 2: Remove existing MCP server if it exists
echo -e "\n${YELLOW}Step 2: Removing existing Autobox MCP server...${NC}"
claude mcp remove autobox 2>/dev/null || true
echo -e "${GREEN}✓ Cleanup complete${NC}"

# Step 3: Add Autobox MCP server to Claude
echo -e "\n${YELLOW}Step 3: Adding Autobox MCP server to Claude...${NC}"
claude mcp add autobox \
  -s user \
  docker \
  run \
  -i \
  --rm \
  --name autobox-mcp \
  -e OPENAI_API_KEY \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -v "${HOME}/.autobox:/root/.autobox" \
  -e HOST_HOME="${HOME}" \
  -e HOST_USER="${USER}" \
  autobox-mcp:latest

if [ $? -eq 0 ]; then
    echo -e "\n${GREEN}✅ Autobox MCP server successfully installed!${NC}"
    echo -e "${GREEN}   Restart Claude Desktop to use the new MCP server.${NC}"
else
    echo -e "${RED}✗ Failed to add MCP server to Claude${NC}"
    exit 1
fi